{
  "$schema": "https://unpkg.com/release-it@19.2.4/schema/release-it.json",
  "git": {
    "requireCleanWorkingDir": true,
    "commitMessage": "build(release): bump schema-builder to ${version}",
    "tagAnnotation": "schema-builder@${version}",
    "tagName": "schema-builder@${version}"
  },
  "npm": { "publish": true, "publishArgs": ["--access=public"], "publishPath": "." },
  "github": { "releaseName": "schema-builder v${version}" },
  "hooks": {
    "before:init": ["bun run tsc", "bun run lint", "bun run test", "bun run build"],
    "before:release": "echo 'Publishing schema-builder v${version}...'",
    "after:release": "echo 'Released schema-builder v${version} successfully! 🎉'",
    "after:git:release": "echo 'Git tag schema-builder@${version} pushed!'"
  }
}
